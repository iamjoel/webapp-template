{
  "name": "@app/db",
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/pglite.ts",
      "default": "./src/neon.ts"
    },
    "./schema": {
      "default": "./src/schema/index.ts"
    }
  },
  "scripts": {
    "check-types": "tsc -b",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:neon": "drizzle-kit migrate --config drizzle.neon.config.ts"
  },
  "dependencies": {
    "@app/env": "workspace:*",
    "@neondatabase/serverless": "^1.1.0",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@app/config": "workspace:*",
    "@electric-sql/pglite": "^0.5.4",
    "drizzle-kit": "^0.31.10",
    "typescript": "catalog:"
  }
}
