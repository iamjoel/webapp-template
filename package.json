{
  "name": "app",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "vp run -r dev",
    "build": "vp run -r build",
    "check-types": "vp run -r check-types",
    "check": "vp check && vp run -r check-types",
    "lint": "vp lint",
    "format": "vp fmt",
    "staged": "vp staged",
    "hooks:setup": "vp config",
    "dev:web": "vp run --filter web dev",
    "dev:server": "vp run --filter server dev",
    "db:push": "vp run --filter @app/db db:push",
    "db:studio": "vp run --filter @app/db db:studio",
    "db:generate": "vp run --filter @app/db db:generate",
    "db:migrate": "vp run --filter @app/db db:migrate",
    "db:migrate:neon": "vercel env run -e production -- pnpm --filter @app/db db:migrate:neon",
    "deploy:setup": "vercel link",
    "dev:vercel": "tsx scripts/dev-vercel.ts",
    "env:preview": "tsx scripts/sync-vercel-env.ts preview",
    "env:production": "tsx scripts/sync-vercel-env.ts production",
    "deploy": "vercel deploy",
    "deploy:prod": "vercel deploy --prod",
    "deploy:check": "vercel deploy --dry"
  },
  "dependencies": {
    "@app/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@app/config": "workspace:*",
    "@types/node": "catalog:",
    "rolldown": "1.1.4",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vercel": "^54.18.6",
    "vite-plus": "0.2.2"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.2"
  },
  "packageManager": "pnpm@11.8.0"
}
